<style>
  :root{
    --ink:#1C1C1C;
    --ink-soft:#2a2724;
    --cream:#FAF3E7;
    --cream-deep:#F1E6D2;
    --paper:#FFFDF8;
    --chili:#C92A2A;
    --chili-dark:#9e1f1f;
    --orange:#E86C2F;
    --gold:#B5853A;
    --gray:#6b6560;
    --line:rgba(28,28,28,.14);
    --shadow:0 18px 40px -18px rgba(28,28,28,.45);
    --shadow-sm:0 8px 22px -12px rgba(28,28,28,.4);
    --display:'Bricolage Grotesque',system-ui,sans-serif;
    --body:'Hanken Grotesk',system-ui,sans-serif;
    --hand:'Caveat',cursive;
    --maxw:1180px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:var(--body);
    color:var(--ink);
    background:var(--cream);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
    /* subtle paper grain */
    background-image:
      radial-gradient(rgba(181,133,58,.035) 1px, transparent 1px);
    background-size:18px 18px;
  }
  h1,h2,h3,h4{font-family:var(--display);line-height:1.02;letter-spacing:-.02em;font-weight:800}
  a{color:inherit;text-decoration:none}
  img{display:block;max-width:100%}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
  .reveal{opacity:0;transform:translateY(26px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}

  /* ---------- wordmark ---------- */
  .wordmark{font-family:var(--display);font-weight:800;letter-spacing:-.03em;line-height:.9}
  .wordmark .c{color:var(--chili)}

  /* ---------- buttons ---------- */
  .btn{
    display:inline-flex;align-items:center;gap:.5rem;
    font-family:var(--display);font-weight:700;font-size:.98rem;
    padding:.85rem 1.5rem;border-radius:999px;cursor:pointer;border:2px solid transparent;
    transition:transform .18s ease,box-shadow .18s ease,background .18s ease,color .18s ease;
    white-space:nowrap;
  }
  .btn-primary{background:var(--chili);color:#fff;box-shadow:var(--shadow-sm)}
  .btn-primary:hover{background:var(--chili-dark);transform:translateY(-2px)}
  .btn-ghost{background:transparent;color:var(--ink);border-color:var(--ink)}
  .btn-ghost:hover{background:var(--ink);color:var(--cream);transform:translateY(-2px)}
  .btn-light{background:var(--cream);color:var(--ink)}
  .btn-light:hover{transform:translateY(-2px);box-shadow:var(--shadow)}

  /* ---------- announcement bar ---------- */
  .announce{
    background:var(--ink);color:var(--cream);font-size:.82rem;
    display:flex;justify-content:center;gap:1.6rem;align-items:center;
    padding:.5rem 1rem;flex-wrap:wrap;font-weight:500;letter-spacing:.02em;
  }
  .announce .dot{width:5px;height:5px;border-radius:50%;background:var(--orange);display:inline-block}
  .announce a{color:var(--cream);font-weight:700;border-bottom:1px solid var(--orange)}

  /* ---------- nav ---------- */
  header.nav{position:sticky;top:0;z-index:50;background:rgba(250,243,231,.86);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;height:74px}
  .brand{font-family:var(--display);font-weight:800;font-size:1.5rem;letter-spacing:-.04em}
  .brand .c{color:var(--chili)}
  .brand small{display:block;font-family:var(--body);font-weight:600;font-size:.56rem;letter-spacing:.42em;color:var(--gray);margin-top:-2px}
  .nav-links{display:flex;align-items:center;gap:2rem}
  .nav-links a{font-weight:600;font-size:.95rem;position:relative}
  .nav-links a:not(.btn)::after{content:"";position:absolute;left:0;bottom:-6px;width:0;height:2px;background:var(--chili);transition:width .25s ease}
  .nav-links a:not(.btn):hover::after{width:100%}
  .menu-toggle{display:none;background:none;border:0;cursor:pointer;font-size:1.6rem}

  /* ---------- hero ---------- */
  .hero{position:relative;min-height:88vh;display:flex;align-items:flex-end;color:var(--cream);overflow:hidden}
  .hero-bg{position:absolute;inset:0;background:#000}
  .hero-bg img{width:100%;height:100%;object-fit:cover;opacity:.62;transform:scale(1.05);animation:slowzoom 14s ease-out forwards}
  @keyframes slowzoom{to{transform:scale(1)}}
  .hero::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,18,16,.55) 0%,rgba(20,18,16,.25) 35%,rgba(20,18,16,.82) 100%);z-index:1}
  .hero-content{position:relative;z-index:2;padding:0 0 70px;width:100%}
  .hero .eyebrow{font-family:var(--hand);font-size:1.7rem;color:#ffd9a0;transform:rotate(-3deg);display:inline-block;margin-bottom:.2rem}
  .hero h1{font-size:clamp(3rem,9vw,7rem);text-transform:uppercase;letter-spacing:-.04em;text-shadow:0 4px 30px rgba(0,0,0,.4)}
  .hero h1 .c{color:var(--orange)}
  .hero .sub{font-size:clamp(1.05rem,2vw,1.35rem);max-width:540px;margin:1.1rem 0 1.8rem;color:#f3e7d4;font-weight:500}
  .hero-cta{display:flex;gap:1rem;flex-wrap:wrap}

  /* ---------- shout band ---------- */
  .shout{background:var(--chili);color:var(--cream);overflow:hidden;padding:.9rem 0;border-top:3px solid var(--ink);border-bottom:3px solid var(--ink)}
  .shout-track{display:flex;gap:3rem;white-space:nowrap;animation:scroll 26s linear infinite;font-family:var(--display);font-weight:800;font-size:1.5rem;text-transform:uppercase;letter-spacing:.02em}
  .shout-track span{display:inline-flex;align-items:center;gap:3rem}
  .shout-track .star{color:#ffd9a0}
  @keyframes scroll{to{transform:translateX(-50%)}}

  /* ---------- section base ---------- */
  section.block{padding:96px 0}
  .kicker{font-family:var(--hand);font-size:1.6rem;color:var(--chili);transform:rotate(-2deg);display:inline-block}
  .section-title{font-size:clamp(2.2rem,5vw,3.6rem);text-transform:uppercase;margin:.2rem 0 .6rem}
  .lede{color:var(--gray);font-size:1.1rem;max-width:560px}

  /* ---------- featured ---------- */
  .featured{background:var(--cream-deep)}
  .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:46px}
  .feat-card{background:var(--paper);border-radius:20px;overflow:hidden;box-shadow:var(--shadow-sm);border:1px solid var(--line);transition:transform .25s ease,box-shadow .25s ease}
  .feat-card:hover{transform:translateY(-8px);box-shadow:var(--shadow)}
  .feat-card .ph{aspect-ratio:4/3;overflow:hidden;background:#ddd}
  .feat-card .ph img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
  .feat-card:hover .ph img{transform:scale(1.07)}
  .feat-body{padding:22px 24px 26px}
  .feat-body h3{font-size:1.4rem;display:flex;justify-content:space-between;align-items:baseline;gap:.5rem}
  .feat-body .price{color:var(--chili);font-family:var(--display);font-weight:800}
  .feat-body p{color:var(--gray);font-size:.95rem;margin-top:.4rem}
  .tag{display:inline-block;font-family:var(--display);font-weight:700;font-size:.68rem;text-transform:uppercase;letter-spacing:.12em;color:var(--orange);background:rgba(232,108,47,.12);padding:.25rem .6rem;border-radius:999px;margin-bottom:.7rem}

  /* ---------- menu ---------- */
  .menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px 56px;margin-top:42px}
  .menu-cat{break-inside:avoid}
  .menu-cat h3{font-size:1.5rem;text-transform:uppercase;color:var(--ink);display:flex;align-items:center;gap:.7rem;margin-bottom:.4rem}
  .menu-cat h3::after{content:"";flex:1;height:2px;background:repeating-linear-gradient(90deg,var(--gold) 0 6px,transparent 6px 12px);opacity:.5}
  .menu-cat .note{font-size:.8rem;color:var(--orange);font-weight:600;margin-bottom:.5rem;font-style:italic}
  .menu-item{display:flex;align-items:baseline;gap:.6rem;padding:.32rem 0;border-bottom:1px dotted var(--line)}
  .menu-item .nm{font-weight:600}
  .menu-item .ln{flex:1}
  .menu-item .pr{font-family:var(--display);font-weight:700;color:var(--ink-soft);white-space:nowrap}
  .menu-foot{margin-top:34px;text-align:center}

  /* ---------- find us ---------- */
  .findus{background:var(--ink);color:var(--cream)}
  .findus .section-title{color:var(--cream)}
  .findus .kicker{color:var(--orange)}
  .find-grid{display:grid;grid-template-columns:1fr 1fr;gap:46px;align-items:center;margin-top:40px}
  .find-info .row{display:flex;gap:.9rem;align-items:flex-start;padding:1rem 0;border-bottom:1px solid rgba(255,255,255,.1)}
  .find-info .ic{font-size:1.4rem;line-height:1.4}
  .find-info h4{font-family:var(--display);font-size:1.05rem;text-transform:uppercase;letter-spacing:.04em;color:#ffd9a0}
  .find-info p,.find-info a{color:#e8ddca;font-size:1rem}
  .find-info a:hover{color:#fff;text-decoration:underline}
  .map-frame{border-radius:20px;overflow:hidden;border:3px solid rgba(255,255,255,.12);box-shadow:var(--shadow);min-height:360px}
  .map-frame iframe{width:100%;height:100%;min-height:360px;border:0;filter:grayscale(.15) contrast(1.02)}

  /* ---------- about / pillars ---------- */
  .about{background:var(--cream)}
  .about-head{text-align:center;max-width:680px;margin:0 auto}
  .pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:50px}
  .pillar{text-align:center;padding:32px 24px;background:var(--paper);border-radius:20px;border:1px solid var(--line);box-shadow:var(--shadow-sm)}
  .pillar .emoji{font-size:2.2rem}
  .pillar h4{font-family:var(--display);font-size:1.2rem;text-transform:uppercase;margin:.7rem 0 .4rem}
  .pillar p{color:var(--gray);font-size:.95rem}

  /* ---------- big CTA ---------- */
  .cta{position:relative;color:var(--cream);text-align:center;overflow:hidden}
  .cta-bg{position:absolute;inset:0}
  .cta-bg img{width:100%;height:100%;object-fit:cover;opacity:.4}
  .cta::before{content:"";position:absolute;inset:0;background:linear-gradient(rgba(28,28,28,.78),rgba(28,28,28,.86));z-index:1}
  .cta .inner{position:relative;z-index:2;padding:110px 24px}
  .cta h2{font-size:clamp(2.4rem,6vw,4.5rem);text-transform:uppercase}
  .cta h2 .c{color:var(--orange)}
  .cta p{font-family:var(--hand);font-size:1.8rem;color:#ffd9a0;margin:.4rem 0 1.6rem;transform:rotate(-2deg)}

  /* ---------- footer ---------- */
  footer.foot{background:var(--ink-soft);color:#d9cdb9;padding:64px 0 28px}
  .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:40px}
  .foot .brand{color:var(--cream);font-size:1.8rem}
  .foot p{font-size:.92rem;margin-top:.8rem;max-width:320px}
  .foot h5{font-family:var(--display);text-transform:uppercase;letter-spacing:.06em;font-size:.85rem;color:#ffd9a0;margin-bottom:1rem}
  .foot ul{list-style:none}
  .foot li{margin-bottom:.6rem;font-size:.95rem}
  .foot a:hover{color:#fff;text-decoration:underline}
  .socials{display:flex;gap:.8rem;margin-top:1rem}
  .socials a{width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.08);display:grid;place-items:center;transition:background .2s ease,transform .2s ease}
  .socials a:hover{background:var(--chili);transform:translateY(-3px)}
  .socials svg{width:20px;height:20px;fill:#e8ddca}
  .socials a:hover svg{fill:#fff}
  .foot-bottom{border-top:1px solid rgba(255,255,255,.1);margin-top:46px;padding-top:22px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;font-size:.8rem;color:#9c917f}

  /* ---------- responsive ---------- */
  @media(max-width:880px){
    .nav-links{position:fixed;inset:74px 0 auto 0;background:var(--cream);flex-direction:column;align-items:stretch;gap:0;padding:10px 24px 24px;border-bottom:1px solid var(--line);transform:translateY(-130%);transition:transform .3s ease;box-shadow:var(--shadow)}
    .nav-links.open{transform:none}
    .nav-links a{padding:.9rem 0;border-bottom:1px solid var(--line)}
    .nav-links a:not(.btn)::after{display:none}
    .nav-links .btn{margin-top:.8rem;justify-content:center}
    .menu-toggle{display:block}
    .feat-grid,.pillars{grid-template-columns:1fr}
    .menu-grid,.find-grid,.foot-grid{grid-template-columns:1fr;gap:34px}
    section.block{padding:64px 0}
    .hero{min-height:80vh}
  }
</style>
</head>
